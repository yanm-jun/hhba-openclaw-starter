{
  "name": "hhba-openclaw-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "hhba-openclaw-setup": "./bin/hhba-openclaw-setup.mjs"
  },
  "scripts": {
    "setup": "node ./scripts/setup.mjs",
    "install:plugin": "npm install --prefix ./plugins/hhba-openclaw",
    "apply-config": "node ./scripts/apply-openclaw-config.mjs",
    "render-config": "node ./scripts/render-config.mjs",
    "render-config:check": "node ./scripts/render-config.mjs --check",
    "smoke": "node ./scripts/smoke-check.mjs"
  }
}
