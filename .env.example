HHBA_BASE_URL=https://api.hhba.com.cn
HHBA_API_TOKEN=REPLACE_WITH_ISSUED_HHBA_API_TOKEN
HHBA_DEFAULT_LIMIT=5
OPENCLAW_PLUGIN_PATH=./plugins/hhba-openclaw
OPENCLAW_CONFIG_OUT=./generated/openclaw.hhba.config.jsonc
OPENCLAW_CONFIG_PATH=
# Optional: OpenClaw Feishu / Lark channel
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ACCOUNT_NAME=HHBA OpenClaw
FEISHU_DM_POLICY=pairing
FEISHU_REQUIRE_MENTION=true
FEISHU_DOMAIN=
FEISHU_CONNECTION_MODE=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_DM_POLICY=open
TELEGRAM_REQUIRE_MENTION=false
HHBA_ENABLE_CREATE_TASK_SMOKE=false
